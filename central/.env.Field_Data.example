# Use fully qualified domain names. Set to DOMAIN=local if SSL_TYPE=selfsign.
DOMAIN=localhost

# Used for Let's Encrypt expiration emails and Enketo technical support emails
SYSADMIN_EMAIL=admin@fieldos.local

# Options: letsencrypt, customssl, upstream, selfsign
SSL_TYPE=selfsign

# Do not change if using SSL_TYPE=letsencrypt
HTTP_PORT=80
HTTPS_PORT=443

# Required for encrypted manual backups.
FIELD_DATA_BACKUP_PASSPHRASE=replace-with-a-long-random-secret
FIELD_DATA_WEBHOOK_ENCRYPTION_KEY=replace-with-32-random-bytes-in-base64

# Docker Compose persists custom media and backups in the field_data volume.
FIELD_DATA_STORAGE_MODE=filesystem
